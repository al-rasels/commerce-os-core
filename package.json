{
  "name": "commerceos-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "CommerceOS multi-tenant e-commerce SaaS platform monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "npm@11.13.0",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "axe-core": "^4.12.1",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "k6": "^0.0.0",
    "lint-staged": "^17.1.0",
    "storybook": "^10.5.2",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.67.0",
    "@sentry/react": "^10.67.0",
    "date-fns": "^4.4.0"
  }
}
