generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code String @unique
  name String

  @@map("countries")
}

model Currency {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String @unique
  symbol         String
  decimal_places Int    @default(2)

  @@map("currencies")
}

model Plan {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  default_flags_json Json   @default("{}")
  price_cents        Int    @default(0)

  @@map("plans")
}

model Tenant {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  plan_id            String                  @default("trial")
  status             String                  @default("active")
  created_at         DateTime                @default(now()) @db.Timestamptz(6)
  audit_logs         AuditLog[]
  cart_items         CartItem[]
  carts              Cart[]
  categories         Category[]
  customers          Customer[]
  flags              FeatureFlag[]
  order_items        OrderItem[]
  orders             Order[]
  page_layouts       PageLayout[]
  variants           ProductVariant[]
  products           Product[]
  promotions         Promotion[]
  roles              Role[]
  shipping_rules     ShippingRule[]
  stock_reservations StockReservation[]
  tax_rules          TaxRule[]
  template_overrides TemplateTenantOverride?
  domains            TenantDomain[]
  theme_overrides    ThemeTenantOverride?
  users              User[]

  @@map("tenants")
}

model TenantDomain {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String  @db.Uuid
  domain     String  @unique
  is_primary Boolean @default(true)
  tenant     Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_domains")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String?  @db.Uuid
  name        String
  permissions String[]
  tenant      Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users       User[]

  @@map("roles")
}

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String?    @db.Uuid
  email         String
  password_hash String
  role_id       String     @db.Uuid
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  mfa_enabled   Boolean    @default(false)
  mfa_secret    String?
  status        String     @default("active")
  audit_logs    AuditLog[]
  role          Role       @relation(fields: [role_id], references: [id])
  tenant        Tenant?    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, email])
  @@map("users")
}

model FeatureFlag {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String  @db.Uuid
  flag_key  String
  enabled   Boolean @default(false)
  tenant    Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, flag_key])
  @@map("feature_flags")
}

model Product {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String           @db.Uuid
  name            String
  slug            String
  status          String           @default("draft")
  category_id     String?          @db.Uuid
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime         @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime?        @db.Timestamptz(6)
  metafields_json Json?            @default("{}")
  description     String?
  variants        ProductVariant[]
  category        Category?        @relation(fields: [category_id], references: [id])
  tenant          Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, slug])
  @@map("products")
}

model ProductVariant {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String             @db.Uuid
  product_id         String             @db.Uuid
  sku                String
  price_cents        Int
  currency           String
  stock_available    Int                @default(0)
  stock_reserved     Int                @default(0)
  attributes_json    Json?
  cart_items         CartItem[]
  order_items        OrderItem[]
  product            Product            @relation(fields: [product_id], references: [id], onDelete: Cascade)
  tenant             Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  stock_reservations StockReservation[]

  @@unique([tenant_id, sku])
  @@map("product_variants")
}

model Category {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String     @db.Uuid
  name       String
  slug       String
  parent_id  String?    @db.Uuid
  sort_order Int        @default(0)
  parent     Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children   Category[] @relation("CategoryHierarchy")
  tenant     Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([tenant_id, slug])
  @@map("categories")
}

model Customer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  email      String
  first_name String?
  last_name  String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  carts      Cart[]
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  orders     Order[]

  @@unique([tenant_id, email])
  @@map("customers")
}

model Cart {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String     @db.Uuid
  customer_id String?    @db.Uuid
  session_id  String?
  status      String     @default("open")
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  items       CartItem[]
  customer    Customer?  @relation(fields: [customer_id], references: [id])
  tenant      Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String         @db.Uuid
  cart_id    String         @db.Uuid
  variant_id String         @db.Uuid
  quantity   Int
  cart       Cart           @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  tenant     Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Order {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String             @db.Uuid
  customer_id        String             @db.Uuid
  status             String             @default("pending")
  subtotal_cents     Int
  tax_cents          Int
  shipping_cents     Int
  total_cents        Int
  currency           String
  channel            String             @default("online")
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  metafields_json    Json?              @default("{}")
  items              OrderItem[]
  customer           Customer           @relation(fields: [customer_id], references: [id])
  tenant             Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  stock_reservations StockReservation[]

  @@map("orders")
}

model OrderItem {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String         @db.Uuid
  order_id         String         @db.Uuid
  variant_id       String         @db.Uuid
  quantity         Int
  unit_price_cents Int
  order            Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  tenant           Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  variant          ProductVariant @relation(fields: [variant_id], references: [id])

  @@map("order_items")
}

model ThemeBase {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  version     String
  tokens_json Json
  overrides   ThemeTenantOverride[]

  @@map("theme_base")
}

model ThemeTenantOverride {
  tenant_id      String    @id @db.Uuid
  theme_base_id  String    @db.Uuid
  overrides_json Json
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)
  tenant         Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  theme_base     ThemeBase @relation(fields: [theme_base_id], references: [id])

  @@map("theme_tenant_override")
}

model TemplateBase {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  version     String
  layout_json Json
  overrides   TemplateTenantOverride[]

  @@map("template_base")
}

model TemplateTenantOverride {
  tenant_id        String       @id @db.Uuid
  template_base_id String       @db.Uuid
  overrides_json   Json         @default("{}")
  updated_at       DateTime     @default(now()) @db.Timestamptz(6)
  template_base    TemplateBase @relation(fields: [template_base_id], references: [id])
  tenant           Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("template_tenant_override")
}

model StockReservation {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String         @db.Uuid
  variant_id String         @db.Uuid
  order_id   String?        @db.Uuid
  quantity   Int
  expires_at DateTime       @db.Timestamptz(6)
  created_at DateTime       @default(now()) @db.Timestamptz(6)
  order      Order?         @relation(fields: [order_id], references: [id])
  tenant     Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([expires_at])
  @@map("stock_reservations")
}

model PageLayout {
  tenant_id     String    @db.Uuid
  page_key      String
  sections_json Json
  published_at  DateTime? @db.Timestamptz(6)
  tenant        Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@id([tenant_id, page_key])
  @@map("page_layouts")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String?  @db.Uuid
  actor_id   String   @db.Uuid
  action     String
  entity     String
  entity_id  String?  @db.Uuid
  diff_json  Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  actor      User     @relation(fields: [actor_id], references: [id])
  tenant     Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("audit_log")
}

model ShippingRule {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String
  type       String
  config     Json
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("shipping_rules")
}

model TaxRule {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String
  type       String
  rate       Float
  region     String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("tax_rules")
}

model Promotion {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String    @db.Uuid
  code       String    @unique
  type       String
  value      Float
  min_order  Float?
  max_uses   Int?
  uses       Int       @default(0)
  expires_at DateTime? @db.Timestamptz(6)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, code])
  @@map("promotions")
}
