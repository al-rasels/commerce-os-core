datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Country {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code String @unique
  name String

  @@map("countries")
}

model Currency {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String @unique
  symbol         String
  decimal_places Int    @default(2)

  @@map("currencies")
}

model Plan {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  default_flags_json Json   @default("{}")
  price_cents        Int    @default(0)

  @@map("plans")
}

model Tenant {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  plan_id             String                   @default("trial")
  status              String                   @default("active") // 'active' | 'suspended' | 'offboarding'
  created_at          DateTime                 @default(now()) @db.Timestamptz
  domains             TenantDomain[]
  users               User[]
  roles               Role[]
  flags               FeatureFlag[]
  products            Product[]
  variants            ProductVariant[]
  categories          Category[]
  customers           Customer[]
  carts               Cart[]
  cart_items          CartItem[]
  orders              Order[]
  order_items         OrderItem[]
  theme_overrides     ThemeTenantOverride[]
  template_overrides  TemplateTenantOverride[]
  page_layouts        PageLayout[]
  stock_reservations  StockReservation[]
  audit_logs          AuditLog[]
  shipping_rules      ShippingRule[]
  tax_rules           TaxRule[]
  promotions          Promotion[]
  bundle_items        ProductBundleItem[]
  company_profiles    CompanyProfile[]
  price_lists         PriceList[]
  subscriptions       Subscription[]
  return_requests     ReturnRequest[]
  inventory_locations InventoryLocation[]
  inventory_levels    InventoryLevel[]

  @@map("tenants")
}

model TenantDomain {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String  @db.Uuid
  domain     String  @unique
  is_primary Boolean @default(true)
  tenant     Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_domains")
}

model Role {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String? @db.Uuid
  name      String // 'super_admin' | 'store_owner' | 'store_staff' | 'customer'
  tenant    Tenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users     User[]

  @@map("roles")
}

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String?    @db.Uuid
  email         String
  password_hash String
  role_id       String     @db.Uuid
  status        String     @default("active") // 'active' | 'pending' | 'suspended'
  mfa_secret    String?
  mfa_enabled   Boolean    @default(false)
  created_at    DateTime   @default(now()) @db.Timestamptz
  tenant        Tenant?    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id])
  audit_logs    AuditLog[]

  @@unique([tenant_id, email])
  @@map("users")
}

model FeatureFlag {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id String  @db.Uuid
  flag_key  String
  enabled   Boolean @default(false)
  tenant    Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, flag_key])
  @@map("feature_flags")
}

model Product {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String           @db.Uuid
  name            String
  slug            String
  product_type    String           @default("physical") // 'physical' | 'digital' | 'bundle'
  status          String           @default("draft") // 'draft' | 'active' | 'archived'
  category_id     String?          @db.Uuid
  created_at      DateTime         @default(now()) @db.Timestamptz
  updated_at      DateTime         @updatedAt @db.Timestamptz
  deleted_at      DateTime?        @db.Timestamptz
  description     String?          @db.Text
  metafields_json Json?            @default("{}")
  tenant          Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [category_id], references: [id], onDelete: SetNull)
  variants        ProductVariant[]

  @@unique([tenant_id, slug])
  @@map("products")
}

model ProductVariant {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String              @db.Uuid
  product_id          String              @db.Uuid
  sku                 String
  price_cents         Int
  currency            String
  stock_available     Int                 @default(0)
  stock_reserved      Int                 @default(0)
  attributes_json     Json?
  tenant              Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product             Product             @relation(fields: [product_id], references: [id], onDelete: Cascade)
  cart_items          CartItem[]
  order_items         OrderItem[]
  stock_reservations  StockReservation[]
  bundle_parent_items ProductBundleItem[] @relation("BundleParent")
  bundle_child_items  ProductBundleItem[] @relation("BundleChild")
  levels              InventoryLevel[]

  @@unique([tenant_id, sku])
  @@map("product_variants")
}

model Category {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String     @db.Uuid
  name       String
  slug       String
  parent_id  String?    @db.Uuid
  sort_order Int        @default(0)
  tenant     Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent     Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children   Category[] @relation("CategoryHierarchy")
  products   Product[]

  @@unique([tenant_id, slug])
  @@map("categories")
}

model Customer {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String          @db.Uuid
  email         String
  first_name    String?
  last_name     String?
  company_id    String?         @db.Uuid
  price_list_id String?         @db.Uuid
  created_at    DateTime        @default(now()) @db.Timestamptz
  tenant        Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  company       CompanyProfile? @relation(fields: [company_id], references: [id], onDelete: SetNull)
  price_list    PriceList?      @relation(fields: [price_list_id], references: [id], onDelete: SetNull)
  carts         Cart[]
  orders        Order[]
  subscriptions Subscription[]

  @@unique([tenant_id, email])
  @@map("customers")
}

model Cart {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String     @db.Uuid
  customer_id  String?    @db.Uuid
  session_id   String?
  status       String     @default("open") // 'open' | 'converted' | 'abandoned'
  promotion_id String?    @db.Uuid
  created_at   DateTime   @default(now()) @db.Timestamptz
  tenant       Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customer     Customer?  @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  promotion    Promotion? @relation(fields: [promotion_id], references: [id], onDelete: SetNull)
  items        CartItem[]

  @@map("carts")
}

model CartItem {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String         @db.Uuid
  cart_id    String         @db.Uuid
  variant_id String         @db.Uuid
  quantity   Int
  tenant     Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cart       Cart           @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Order {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String             @db.Uuid
  customer_id        String             @db.Uuid
  status             String             @default("pending") // 'pending' | 'paid' | 'fulfilled' | 'cancelled' | 'refunded'
  subtotal_cents     Int
  tax_cents          Int
  shipping_cents     Int
  discount_cents     Int                @default(0)
  total_cents        Int
  currency           String
  channel            String             @default("online") // 'online' | 'pos'
  created_at         DateTime           @default(now()) @db.Timestamptz
  metafields_json    Json?              @default("{}")
  tenant             Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customer           Customer           @relation(fields: [customer_id], references: [id])
  items              OrderItem[]
  stock_reservations StockReservation[]
  subscriptions      Subscription[]
  return_requests    ReturnRequest[]

  @@map("orders")
}

model OrderItem {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String         @db.Uuid
  order_id         String         @db.Uuid
  variant_id       String         @db.Uuid
  quantity         Int
  unit_price_cents Int
  tenant           Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  order            Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant          ProductVariant @relation(fields: [variant_id], references: [id])

  @@map("order_items")
}

model ThemeBase {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  version     String
  tokens_json Json
  overrides   ThemeTenantOverride[]

  @@map("theme_base")
}

model ThemeTenantOverride {
  tenant_id      String    @id @db.Uuid
  theme_base_id  String    @db.Uuid
  overrides_json Json
  updated_at     DateTime  @default(now()) @db.Timestamptz
  tenant         Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  theme_base     ThemeBase @relation(fields: [theme_base_id], references: [id])

  @@map("theme_tenant_override")
}

model TemplateBase {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  version     String
  layout_json Json
  overrides   TemplateTenantOverride[]

  @@map("template_base")
}

model TemplateTenantOverride {
  tenant_id        String       @id @db.Uuid
  template_base_id String       @db.Uuid
  overrides_json   Json         @default("{}")
  updated_at       DateTime     @default(now()) @db.Timestamptz
  tenant           Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  template_base    TemplateBase @relation(fields: [template_base_id], references: [id])

  @@map("template_tenant_override")
}

model StockReservation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String   @db.Uuid
  variant_id  String   @db.Uuid
  order_id    String?  @db.Uuid
  location_id String?  @db.Uuid
  quantity    Int
  expires_at  DateTime @db.Timestamptz

  tenant   Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  variant  ProductVariant     @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  order    Order?             @relation(fields: [order_id], references: [id], onDelete: SetNull)
  location InventoryLocation? @relation(fields: [location_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([expires_at])
  @@map("stock_reservations")
}

model PageLayout {
  tenant_id     String    @db.Uuid
  page_key      String // 'homepage' | 'category' | 'product' | 'checkout'
  sections_json Json
  published_at  DateTime? @db.Timestamptz
  tenant        Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@id([tenant_id, page_key])
  @@map("page_layouts")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String?  @db.Uuid
  actor_id   String   @db.Uuid
  action     String
  entity     String
  entity_id  String?  @db.Uuid
  diff_json  Json?
  created_at DateTime @default(now()) @db.Timestamptz
  tenant     Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  actor      User     @relation(fields: [actor_id], references: [id])

  @@map("audit_log")
}

model ShippingRule {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String
  type       String // 'flat_rate' | 'weight_tier'
  config     Json // JSONB
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("shipping_rules")
}

model TaxRule {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String
  type       String // 'flat' | 'region'
  rate       Float // Percentage (e.g. 10.5 for 10.5%)
  region     String? // e.g. 'US-CA', 'UK'
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("tax_rules")
}

model Promotion {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String    @db.Uuid
  code       String
  type       String // 'percentage' | 'fixed_amount'
  value      Float // e.g. 10 for 10%, or 500 for .00
  min_order  Float? // Minimum order subtotal to apply
  max_uses   Int? // Maximum number of times this code can be used
  uses       Int       @default(0)
  expires_at DateTime? @db.Timestamptz
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  carts  Cart[]

  @@index([tenant_id, code])
  @@map("promotions")
}

model ProductBundleItem {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String @db.Uuid
  parent_variant_id String @db.Uuid
  child_variant_id  String @db.Uuid
  quantity          Int    @default(1)

  tenant         Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent_variant ProductVariant @relation("BundleParent", fields: [parent_variant_id], references: [id], onDelete: Cascade)
  child_variant  ProductVariant @relation("BundleChild", fields: [child_variant_id], references: [id], onDelete: Cascade)

  @@unique([parent_variant_id, child_variant_id])
  @@map("product_bundle_items")
}

model CompanyProfile {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String     @db.Uuid
  name               String
  tax_id             String?
  payment_terms      String     @default("due_on_receipt") // 'net_15', 'net_30', 'net_60'
  credit_limit_cents Int?
  tenant             Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customers          Customer[]

  @@map("company_profiles")
}

model PriceList {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String     @db.Uuid
  name       String
  currency   String
  rules_json Json
  tenant     Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customers  Customer[]

  @@map("price_lists")
}

model Subscription {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String   @db.Uuid
  customer_id     String   @db.Uuid
  order_id        String   @db.Uuid
  status          String   @default("active") // 'active'|'paused'|'cancelled'|'past_due'
  interval        String // 'daily'|'weekly'|'monthly'|'yearly'
  interval_count  Int      @default(1)
  next_billing_at DateTime @db.Timestamptz
  tenant          Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customer        Customer @relation(fields: [customer_id], references: [id])
  order           Order    @relation(fields: [order_id], references: [id])

  @@map("subscriptions")
}

model ReturnRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  order_id   String   @db.Uuid
  status     String   @default("pending") // 'pending'|'approved'|'rejected'|'received'|'refunded'
  reason     String
  created_at DateTime @default(now()) @db.Timestamptz
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  order      Order    @relation(fields: [order_id], references: [id])

  @@map("return_requests")
}

model InventoryLocation {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String             @db.Uuid
  name         String
  is_default   Boolean?           @default(false)
  address_json Json
  tenant       Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  levels       InventoryLevel[]
  reservations StockReservation[]

  @@map("inventory_locations")
}

model InventoryLevel {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String            @db.Uuid
  location_id     String            @db.Uuid
  variant_id      String            @db.Uuid
  stock_available Int               @default(0)
  tenant          Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  location        InventoryLocation @relation(fields: [location_id], references: [id], onDelete: Cascade)
  variant         ProductVariant    @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([location_id, variant_id])
  @@map("inventory_levels")
}
